---
const repo = "https://github.com/JiriMachynka/emberyx";
const releases = `${repo}/releases/latest`;
const version = "v0.1.1";
---

<header class="border-b border-line-soft">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-5">
    <a href="/" class="flex items-center gap-2.5 text-sm font-medium">
      <img src="/emberyx.png" alt="Emberyx" width="22" height="22" class="rounded" />
      <span>Emberyx</span>
      <span class="font-mono text-xs text-ash-dim">{version}</span>
    </a>

    <div class="flex items-center gap-7 text-sm text-ash">
      <a href="#features" class="hidden transition-colors hover:text-white sm:inline">Features</a>
      <a href="/docs" class="hidden transition-colors hover:text-white sm:inline">Docs</a>
      <a href={repo} class="transition-colors hover:text-white">GitHub</a>
      <a href={releases} class="text-white transition-colors hover:text-ember-soft">
        Download&nbsp;<span class="text-ash-dim">↓</span>
      </a>
    </div>
  </nav>
</header>
