---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Emberyx — Desktop cockpit for AI coding agents",
  description = "Run Claude Code across all your projects from one native macOS cockpit: integrated terminals, thread resume, inline git, and a live token & cost meter.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/emberyx.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/emberyx.png" />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#140b06" />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
